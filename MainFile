<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DebateLearn — Master the Art of Debate</title>
<meta name="description" content="Learn debate, practice against AI, and dissect any topic with DebateLearn.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0d0d0f;--bg2:#141417;--bg3:#1c1c21;--bg4:#242429;--bg5:#2c2c32;
  --border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.13);--border3:rgba(255,255,255,0.22);
  --text:#f0ede8;--text2:#9a9791;--text3:#5c5a58;--text4:#3a3836;
  --gold:#c8a96e;--gold2:#e8c98a;--gold3:#a8893e;--gold-dim:rgba(200,169,110,0.13);--gold-dim2:rgba(200,169,110,0.22);
  --red:#d64e3b;--red2:#e8705f;--red-dim:rgba(214,78,59,0.11);
  --blue:#4a8fd4;--blue2:#6aaaf0;--blue-dim:rgba(74,143,212,0.11);
  --green:#4aab6d;--green2:#6acb8d;--green-dim:rgba(74,171,109,0.11);
  --purple:#9b72d4;--purple-dim:rgba(155,114,212,0.11);
  --amber:#d4943a;--amber-dim:rgba(212,148,58,0.11);
  --r:8px;--r2:14px;--r3:20px;
}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;line-height:1.6;font-size:15px}
.screen{display:none;min-height:100vh}
.screen.active{display:flex;flex-direction:column}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--bg5);border-radius:2px}
 
/* ══════════ HOME ══════════ */
#home{align-items:center;justify-content:center;padding:2rem;position:relative;overflow:hidden;min-height:100vh}
#home::before{content:'';position:absolute;top:-20%;left:50%;transform:translateX(-50%);width:700px;height:700px;background:radial-gradient(circle,rgba(200,169,110,0.055) 0%,transparent 65%);pointer-events:none}
#home::after{content:'';position:absolute;bottom:-10%;right:-10%;width:400px;height:400px;background:radial-gradient(circle,rgba(74,143,212,0.04) 0%,transparent 70%);pointer-events:none}
.home-inner{max-width:820px;width:100%;text-align:center;position:relative;z-index:1}
.logo-mark{display:inline-flex;align-items:center;gap:12px;margin-bottom:2.5rem}
.logo-icon{width:46px;height:46px;border:1.5px solid var(--gold);border-radius:11px;display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:24px;color:var(--gold)}
.logo-text{font-family:'Playfair Display',serif;font-size:24px;color:var(--text);letter-spacing:-0.02em}
.logo-text span{color:var(--gold)}
.home-eyebrow{font-size:0.7rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--gold3);margin-bottom:1rem;display:flex;align-items:center;justify-content:center;gap:10px}
.home-eyebrow::before,.home-eyebrow::after{content:'';flex:1;max-width:60px;height:1px;background:var(--border2)}
.home-headline{font-family:'Playfair Display',serif;font-size:clamp(2.6rem,5.5vw,4.4rem);font-weight:900;line-height:1.08;letter-spacing:-0.035em;margin-bottom:1.4rem}
.home-headline em{font-style:italic;color:var(--gold)}
.home-sub{font-size:1.05rem;color:var(--text2);max-width:500px;margin:0 auto 3rem;font-weight:300;line-height:1.7}
.mode-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:2.5rem}
@media(max-width:660px){.mode-grid{grid-template-columns:1fr}}
.mode-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);padding:1.8rem 1.5rem;cursor:pointer;transition:all 0.22s ease;text-align:left;position:relative;overflow:hidden}
.mode-card::after{content:'';position:absolute;inset:0;opacity:0;transition:opacity 0.22s;border-radius:inherit}
.mode-card.gold::after{background:var(--gold-dim)}
.mode-card.red::after{background:var(--red-dim)}
.mode-card.blue::after{background:var(--blue-dim)}
.mode-card:hover{border-color:var(--border2);transform:translateY(-3px)}
.mode-card:hover::after{opacity:1}
.mode-number{font-family:'DM Mono',monospace;font-size:0.68rem;color:var(--text3);margin-bottom:1rem;letter-spacing:0.06em}
.mode-icon{font-size:1.9rem;margin-bottom:0.9rem;display:block}
.mode-tag{font-size:0.65rem;letter-spacing:0.14em;text-transform:uppercase;margin-bottom:0.5rem}
.mode-card.gold .mode-tag{color:var(--gold)}
.mode-card.red .mode-tag{color:var(--red)}
.mode-card.blue .mode-tag{color:var(--blue)}
.mode-title{font-family:'Playfair Display',serif;font-size:1.25rem;font-weight:700;margin-bottom:0.6rem;line-height:1.2}
.mode-desc{font-size:0.83rem;color:var(--text2);line-height:1.55}
.mode-arrow{position:absolute;bottom:1.4rem;right:1.4rem;color:var(--text3);font-size:1.1rem;transition:all 0.2s}
.mode-card:hover .mode-arrow{color:var(--text2);transform:translate(2px,-2px)}
.home-footer{font-size:0.75rem;color:var(--text3);display:flex;align-items:center;justify-content:center;gap:8px}
.home-footer::before{content:'✦';color:var(--text4)}
.home-footer::after{content:'✦';color:var(--text4)}
 
/* ══════════ APP BAR ══════════ */
.app-bar{display:flex;align-items:center;gap:12px;padding:0.9rem 1.5rem;border-bottom:1px solid var(--border);background:rgba(13,13,15,0.95);backdrop-filter:blur(12px);flex-shrink:0;position:sticky;top:0;z-index:50}
.app-bar-title{font-family:'Playfair Display',serif;font-size:1.05rem;font-weight:700}
.app-bar-badge{font-size:0.7rem;background:var(--gold-dim);color:var(--gold);border:1px solid rgba(200,169,110,0.25);padding:2px 10px;border-radius:20px;letter-spacing:0.06em}
.app-bar-right{margin-left:auto;display:flex;align-items:center;gap:10px}
.btn-back{background:var(--bg3);border:1px solid var(--border);color:var(--text2);padding:6px 14px;border-radius:var(--r);font-size:0.8rem;cursor:pointer;transition:all 0.18s;font-family:'DM Sans',sans-serif}
.btn-back:hover{border-color:var(--border2);color:var(--text)}
 
/* ══════════ BUTTONS ══════════ */
.btn{padding:10px 22px;border-radius:var(--r);font-size:0.88rem;font-weight:500;cursor:pointer;transition:all 0.18s;border:none;font-family:'DM Sans',sans-serif;display:inline-flex;align-items:center;gap:6px}
.btn-primary{background:var(--gold);color:#0d0d0f}
.btn-primary:hover{background:var(--gold2)}
.btn-ghost{background:transparent;border:1px solid var(--border2);color:var(--text)}
.btn-ghost:hover{background:var(--bg3)}
.btn-sm{padding:7px 14px;font-size:0.8rem}
.btn:disabled{opacity:0.35;cursor:not-allowed}
input,textarea,select{background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:var(--r);padding:10px 14px;font-family:'DM Sans',sans-serif;font-size:0.88rem;transition:border 0.18s;width:100%}
input:focus,textarea:focus,select:focus{outline:none;border-color:var(--gold)}
textarea{resize:vertical}
label{display:block;font-size:0.74rem;color:var(--text2);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.09em}
.form-row{margin-bottom:1.2rem}
.chip{display:inline-flex;align-items:center;gap:5px;background:var(--bg3);border:1px solid var(--border);border-radius:20px;padding:4px 12px;font-size:0.78rem;color:var(--text2);cursor:pointer;transition:all 0.15s}
.chip:hover{border-color:var(--border2);color:var(--text)}
.chip.active{background:var(--gold-dim);border-color:rgba(200,169,110,0.35);color:var(--gold)}
 
/* ══════════ LEARNING SCREEN ══════════ */
#learn{}
.learn-layout{display:grid;grid-template-columns:300px 1fr;flex:1;height:calc(100vh - 57px);overflow:hidden}
@media(max-width:760px){.learn-layout{grid-template-columns:1fr;height:auto}}
.learn-sidebar{border-right:1px solid var(--border);overflow-y:auto;background:var(--bg2);display:flex;flex-direction:column}
.sidebar-search{padding:1rem;border-bottom:1px solid var(--border)}
.sidebar-search input{background:var(--bg3);border-color:var(--border);font-size:0.82rem}
.sidebar-progress-banner{padding:1rem 1.2rem;border-bottom:1px solid var(--border);background:var(--gold-dim)}
.spb-label{font-size:0.7rem;color:var(--gold3);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:6px}
.spb-bar{height:5px;background:rgba(200,169,110,0.2);border-radius:3px;overflow:hidden;margin-bottom:5px}
.spb-fill{height:100%;background:var(--gold);border-radius:3px;transition:width 0.5s ease}
.spb-count{font-size:0.75rem;color:var(--gold);font-family:'DM Mono',monospace}
.sidebar-unit{padding-bottom:0.5rem}
.unit-header{padding:0.7rem 1.2rem;display:flex;align-items:center;gap:8px;cursor:pointer;user-select:none}
.unit-header:hover{background:var(--bg3)}
.unit-number{font-family:'DM Mono',monospace;font-size:0.62rem;color:var(--text3)}
.unit-name{font-size:0.82rem;font-weight:500;flex:1}
.unit-chevron{font-size:0.65rem;color:var(--text3);transition:transform 0.2s}
.unit-chevron.open{transform:rotate(90deg)}
.unit-lessons{padding:0 0.5rem 0.5rem}
.lesson-item{display:flex;align-items:center;gap:9px;padding:7px 10px;border-radius:var(--r);cursor:pointer;transition:background 0.15s;font-size:0.83rem;border:1px solid transparent;margin-bottom:1px}
.lesson-item:hover{background:var(--bg3)}
.lesson-item.active{background:var(--gold-dim);border-color:rgba(200,169,110,0.2);color:var(--gold2)}
.lesson-item.locked{opacity:0.4;cursor:not-allowed}
.lesson-status{width:18px;height:18px;border-radius:50%;border:1.5px solid var(--border2);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:0.65rem}
.lesson-status.done{background:var(--green);border-color:var(--green);color:white}
.lesson-status.active{background:var(--gold-dim);border-color:var(--gold);color:var(--gold)}
.lesson-type-tag{margin-left:auto;font-size:0.6rem;padding:1px 6px;border-radius:4px;font-family:'DM Mono',monospace}
.tag-lesson{background:var(--blue-dim);color:var(--blue)}
.tag-exercise{background:var(--purple-dim);color:var(--purple)}
.tag-quiz{background:var(--amber-dim);color:var(--amber)}
.tag-practice{background:var(--red-dim);color:var(--red2)}
 
/* LEARN MAIN */
.learn-main-wrap{display:flex;flex-direction:column;flex:1;overflow:hidden}
.learn-main{flex:1;overflow-y:auto;padding:2rem 2.5rem}
@media(max-width:900px){.learn-main{padding:1.5rem}}
 
/* Content types */
.lesson-hero{margin-bottom:2rem;padding-bottom:1.5rem;border-bottom:1px solid var(--border)}
.lesson-eyebrow{font-size:0.68rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--gold3);margin-bottom:0.7rem;display:flex;align-items:center;gap:8px}
.lesson-title-big{font-family:'Playfair Display',serif;font-size:clamp(1.6rem,3vw,2.2rem);font-weight:700;line-height:1.15;margin-bottom:0.8rem}
.lesson-lead{font-size:1rem;color:var(--text2);line-height:1.75;max-width:640px}
.meta-pills{display:flex;flex-wrap:wrap;gap:8px;margin-top:1rem}
.meta-pill{background:var(--bg3);border:1px solid var(--border);border-radius:20px;padding:3px 12px;font-size:0.74rem;color:var(--text2);display:inline-flex;align-items:center;gap:5px}
 
/* Lesson body */
.lesson-body h2{font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:700;margin:2rem 0 0.8rem;line-height:1.2}
.lesson-body h3{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;margin:1.5rem 0 0.6rem;color:var(--text)}
.lesson-body p{color:var(--text2);margin-bottom:1rem;line-height:1.75;font-size:0.93rem}
.lesson-body ul,.lesson-body ol{padding-left:1.4rem;color:var(--text2);font-size:0.9rem;margin-bottom:1rem}
.lesson-body li{margin-bottom:0.5rem;line-height:1.65}
.lesson-body strong{color:var(--text);font-weight:500}
 
.callout{border-radius:var(--r2);padding:1.1rem 1.3rem;margin:1.2rem 0;font-size:0.88rem;line-height:1.65}
.callout-example{background:var(--bg3);border-left:3px solid var(--gold);border-radius:0 var(--r) var(--r) 0}
.callout-example .callout-label{color:var(--gold);font-size:0.68rem;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:6px;font-family:'DM Mono',monospace}
.callout-example p{color:var(--text2);margin:0;font-style:italic}
.callout-warning{background:var(--red-dim);border:1px solid rgba(214,78,59,0.2)}
.callout-warning .callout-label{color:var(--red2)}
.callout-tip{background:var(--blue-dim);border:1px solid rgba(74,143,212,0.2)}
.callout-tip .callout-label{color:var(--blue2)}
.callout-insight{background:var(--purple-dim);border:1px solid rgba(155,114,212,0.2)}
.callout-insight .callout-label{color:var(--purple)}
 
/* Framework cards */
.framework-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:10px;margin:1.2rem 0}
.framework-card{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r2);padding:1rem 1.1rem}
.fc-letter{font-family:'Playfair Display',serif;font-size:2rem;font-weight:900;color:var(--gold);line-height:1;margin-bottom:0.4rem}
.fc-name{font-size:0.85rem;font-weight:500;margin-bottom:0.3rem}
.fc-desc{font-size:0.78rem;color:var(--text2);line-height:1.5}
 
/* Comparison table */
.compare-table{width:100%;border-collapse:collapse;margin:1.2rem 0;font-size:0.85rem}
.compare-table th{background:var(--bg3);padding:10px 14px;text-align:left;font-size:0.72rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--text2);border-bottom:1px solid var(--border)}
.compare-table td{padding:9px 14px;border-bottom:1px solid var(--border);color:var(--text2);vertical-align:top;line-height:1.5}
.compare-table tr:hover td{background:var(--bg3)}
.compare-table .highlight{color:var(--gold);font-weight:500}
 
/* Interactive exercises */
.exercise-box{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);padding:1.4rem;margin:1.5rem 0}
.exercise-header{display:flex;align-items:center;gap:10px;margin-bottom:1rem;padding-bottom:0.8rem;border-bottom:1px solid var(--border)}
.exercise-icon{width:34px;height:34px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0}
.exercise-title{font-size:0.92rem;font-weight:500}
.exercise-subtitle{font-size:0.78rem;color:var(--text2)}
 
/* Fallacy cards */
.fallacy-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:10px;margin:1.2rem 0}
.fallacy-card{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r2);padding:1.1rem;position:relative;overflow:hidden}
.fallacy-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px}
.fallacy-card.red::before{background:var(--red)}
.fallacy-card.amber::before{background:var(--amber)}
.fallacy-card.purple::before{background:var(--purple)}
.fallacy-card.blue::before{background:var(--blue)}
.fallacy-name{font-size:0.9rem;font-weight:500;margin-bottom:0.3rem}
.fallacy-latin{font-size:0.7rem;color:var(--text3);font-style:italic;margin-bottom:0.5rem;font-family:'DM Mono',monospace}
.fallacy-def{font-size:0.8rem;color:var(--text2);line-height:1.55;margin-bottom:0.6rem}
.fallacy-example{font-size:0.78rem;color:var(--text3);font-style:italic;border-top:1px solid var(--border);padding-top:0.5rem}
 
/* Quiz */
.quiz-section{background:var(--bg2);border:1px solid var(--border2);border-radius:var(--r2);padding:1.4rem;margin-top:2rem}
.quiz-header{display:flex;align-items:center;gap:10px;margin-bottom:1rem}
.quiz-badge{background:var(--amber-dim);color:var(--amber);border:1px solid rgba(212,148,58,0.25);font-size:0.68rem;letter-spacing:0.1em;text-transform:uppercase;padding:3px 10px;border-radius:4px;font-family:'DM Mono',monospace}
.quiz-q{font-size:0.95rem;font-weight:500;margin-bottom:1rem;line-height:1.5}
.quiz-opts{display:flex;flex-direction:column;gap:7px}
.quiz-opt{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);padding:10px 14px;cursor:pointer;transition:all 0.18s;font-size:0.86rem;text-align:left;font-family:'DM Sans',sans-serif;color:var(--text2);line-height:1.5}
.quiz-opt:hover:not(:disabled){border-color:var(--border2);color:var(--text);background:var(--bg4)}
.quiz-opt.correct{border-color:var(--green);background:var(--green-dim);color:var(--green2)}
.quiz-opt.wrong{border-color:var(--red);background:var(--red-dim);color:var(--red2)}
.quiz-opt:disabled{cursor:default}
.quiz-feedback{margin-top:0.8rem;padding:0.8rem 1rem;border-radius:var(--r);font-size:0.85rem;line-height:1.5}
.quiz-feedback.success{background:var(--green-dim);color:var(--green2)}
.quiz-feedback.fail{background:var(--red-dim);color:var(--red2)}
 
/* AI Exercise */
.ai-exercise{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);padding:1.4rem;margin:1.5rem 0}
.ai-prompt-box{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);padding:1rem;margin-bottom:1rem;font-size:0.88rem;color:var(--text2);line-height:1.6;font-style:italic}
.ai-response-box{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);padding:1rem;margin-top:0.8rem;font-size:0.85rem;color:var(--text2);line-height:1.65;min-height:60px}
.ai-response-box.loading{display:flex;align-items:center;gap:8px;color:var(--text3)}
.ai-label{font-size:0.68rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--text3);margin-bottom:6px;font-family:'DM Mono',monospace}
.typing-dots{display:inline-flex;gap:3px}
.typing-dot{width:5px;height:5px;border-radius:50%;background:var(--text3);animation:blink 1.2s ease-in-out infinite}
.typing-dot:nth-child(2){animation-delay:0.2s}
.typing-dot:nth-child(3){animation-delay:0.4s}
@keyframes blink{0%,80%,100%{opacity:0.2}40%{opacity:1}}
 
/* Lesson nav */
.lesson-nav{display:flex;justify-content:space-between;align-items:center;padding:1rem 1.5rem;border-top:1px solid var(--border);flex-shrink:0;background:var(--bg)}
.lesson-nav-center{display:flex;flex-direction:column;align-items:center;gap:4px;flex:1;margin:0 1rem}
.nav-label{font-size:0.7rem;color:var(--text3)}
 
/* ══════════ ARENA ══════════ */
.arena-setup{max-width:620px;margin:0 auto;padding:2rem 1.5rem;flex:1;overflow-y:auto}
.arena-setup-title{font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:700;margin-bottom:0.4rem}
.arena-setup-sub{color:var(--text2);font-size:0.88rem;margin-bottom:2rem}
.vs-toggle{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:1.4rem}
.vs-btn{padding:12px;border-radius:var(--r);border:1px solid var(--border);background:var(--bg3);color:var(--text2);cursor:pointer;font-size:0.86rem;font-family:'DM Sans',sans-serif;transition:all 0.18s;text-align:center}
.vs-btn:hover{border-color:var(--border2);color:var(--text)}
.vs-btn.active{border-color:rgba(200,169,110,0.45);background:var(--gold-dim);color:var(--gold2)}
.difficulty-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:8px}
.diff-btn{padding:10px 8px;border-radius:var(--r);border:1px solid var(--border);background:var(--bg3);color:var(--text2);cursor:pointer;font-size:0.8rem;font-family:'DM Sans',sans-serif;transition:all 0.18s;text-align:center}
.diff-btn:hover{border-color:var(--border2);color:var(--text)}
.diff-btn.active{border-color:rgba(200,169,110,0.45);background:var(--gold-dim);color:var(--gold2)}
.battle-screen{display:none;flex-direction:column;flex:1;height:calc(100vh - 57px)}
.battle-screen.active{display:flex}
.battle-header{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;padding:0.9rem 1.5rem;border-bottom:1px solid var(--border);gap:1rem;flex-shrink:0}
.combatant{display:flex;align-items:center;gap:10px}
.combatant.right{flex-direction:row-reverse;text-align:right}
.combatant-avatar{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0}
.combatant-name{font-size:0.88rem;font-weight:500}
.combatant-stance{font-size:0.72rem;color:var(--text2)}
.motion-display{text-align:center}
.motion-label{font-size:0.62rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--text3);margin-bottom:3px}
