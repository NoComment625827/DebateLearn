async function sendArg() {
  const inp = document.getElementById('compose-input');
  const text = inp.value.trim();
  if (!text || isTyping) return;
  inp.value = ''; debateRound++;
  if (opponentType === 'human') {
    addMsg(text, p2Turn ? 'ai' : 'user', p2Turn ? document.getElementById('opp-name').textContent : 'Player 1');
    p2Turn = !p2Turn; updateTurnIndicator(); return;
  }
  addMsg(text, 'user'); chatHistory.push({ role: 'user', content: text });
  isTyping = true; updateTurnIndicator(); showTyping();
  const diffs = {
    Novice: 'You are a novice debater. Keep responses to 2-3 sentences. Occasionally use weak evidence or slightly fallacious reasoning. Be earnest but limited.',
    Intermediate: 'You are an intermediate debater. Respond with 3-5 sentences using clear logic, occasional statistics, and direct rebuttals. Push back on weak points.',
    Expert: 'You are an expert competitive debater. Use 4-6 sentences. Deploy rigorous logic, cite specific evidence, name any logical fallacies in your opponent\'s argument, and make incisive rebuttals. Be sophisticated and precise.'
  };
  const system = `${diffs[aiDifficulty]}\nMotion: "${debateMotion}"\nYour position: ${userStance === 'FOR' ? 'AGAINST' : 'FOR'} the motion.\nRespond only with your debate argument. Stay in character.`;
  try {
