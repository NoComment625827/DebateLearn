    removeTyping(); chatHistory.push({ role: 'assistant', content: reply });
    addMsg(reply, 'ai'); document.getElementById('arena-bar-sub').textContent = `Round ${debateRound}`;
  } catch(e) { removeTyping(); addMsg('(Connection error)', 'ai'); }
  isTyping = false; updateTurnIndicator();
}
 
