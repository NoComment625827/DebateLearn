  const results = document.getElementById('bd-results');
  results.style.display = 'block';
  results.innerHTML = `<div class="loading-state"><div class="spinner"></div><p style="font-size:0.85rem">Analysing "${motion}"…</p></div>`;
  const prompt = `Analyse this debate motion: "${motion}"\n\nRespond ONLY in raw JSON (no markdown, no backticks):\n{"motion_summary":"one sentence","ethical_angles":["a1","a2","a3"],"economic_angles":["a1","a2","a3"],"political_angles":["a1","a2","a3"],"pro_arguments":["a1","a2","a3","a4"],"con_arguments":["a1","a2","a3","a4"],"steelman_pro":"2 sentences","steelman_con":"2 sentences","key_statistics":[{"label":"l","value":"v","source":"s"},{"label":"l","value":"v","source":"s"},{"label":"l","value":"v","source":"s"}],"fallacies_to_watch":[{"name":"n","description":"d"},{"name":"n","description":"d"},{"name":"n","description":"d"}],"argument_strengths":{"ethical":<1-10>,"economic":<1-10>,"political":<1-10>,"empirical":<1-10>},"complexity":<1-10>,"controversy":<1-10>}`;
  try {
    let raw = await callClaude([{ role: 'user', content: prompt }]);
    raw = raw.replace(/```json|```/g,'').trim();
    const bd = JSON.parse(raw);
    ['ethical','economic','political'].forEach(t => {
      const el = document.getElementById(`angle-${t}`);
      if (el) el.innerHTML = (bd[`${t}_angles`]||[]).map(a=>`<li>${a}</li>`).join('');
    });
    document.getElementById('bd-angles-area').style.display = '';
    renderBD(bd, motion);
  } catch(e) {
    results.innerHTML = `<div class="loading-state"><p style="color:var(--red)">Failed to analyse. Please check your connection.</p></div>`;
  }
}
 
function renderBD(bd, motion) {
  const results = document.getElementById('bd-results');
  const str = bd.argument_strengths || {};
  results.innerHTML = `
  <div class="bd-section"><div class="bd-section-title">Overview</div>
    <div style="background:var(--bg3);border:1px solid var(--border);border-radius:var(--r2);padding:1.1rem">
      <div style="font-family:'Playfair Display',serif;font-size:1rem;font-style:italic;margin-bottom:0.5rem">"${motion}"</div>
      <p style="font-size:0.85rem;color:var(--text2)">${bd.motion_summary||''}</p>
      <div style="display:flex;gap:1rem;margin-top:0.8rem">
        <div class="stat-row" style="flex:1;border:none;padding:0"><span class="stat-label">Complexity</span><span class="stat-val">${bd.complexity||'—'}/10</span></div>
        <div class="stat-row" style="flex:1;border:none;padding:0"><span class="stat-label">Controversy</span><span class="stat-val">${bd.controversy||'—'}/10</span></div>
      </div>
    </div>
  </div>
  <div class="bd-section"><div class="bd-section-title">For vs Against</div>
    <div class="grid-2">
      <div class="pro-con-card pro"><div class="pro-con-label">For the Motion</div><ul class="pro-con-list">${(bd.pro_arguments||[]).map(a=>`<li>✓ ${a}</li>`).join('')}</ul></div>
      <div class="pro-con-card con"><div class="pro-con-label">Against the Motion</div><ul class="pro-con-list">${(bd.con_arguments||[]).map(a=>`<li>✗ ${a}</li>`).join('')}</ul></div>
    </div>
  </div>
  <div class="bd-section"><div class="bd-section-title">Steelman Arguments</div>
    <div style="background:var(--bg3);border:1px solid var(--border);border-left:3px solid var(--green);border-radius:0 var(--r2) var(--r2) 0;padding:1rem;margin-bottom:8px">
      <div style="font-size:0.65rem;color:var(--green);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:5px">Strongest case FOR</div>
      <p style="font-size:0.85rem;color:var(--text2)">${bd.steelman_pro||''}</p>
    </div>
    <div style="background:var(--bg3);border:1px solid var(--border);border-left:3px solid var(--red);border-radius:0 var(--r2) var(--r2) 0;padding:1rem">
      <div style="font-size:0.65rem;color:var(--red);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:5px">Strongest case AGAINST</div>
      <p style="font-size:0.85rem;color:var(--text2)">${bd.steelman_con||''}</p>
    </div>
  </div>
  <div class="bd-section"><div class="bd-section-title">Key Statistics</div>
    ${(bd.key_statistics||[]).map(s=>`<div class="stat-row"><span class="stat-label">${s.label} <span style="font-size:0.7rem;color:var(--text3)">(${s.source})</span></span><span class="stat-val">${s.value}</span></div>`).join('')}
  </div>
  <div class="bd-section"><div class="bd-section-title">Fallacies to Watch</div>
    ${(bd.fallacies_to_watch||[]).map(f=>`<div style="background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);padding:10px 13px;margin-bottom:7px"><div style="font-size:0.85rem;font-weight:500;color:var(--red);margin-bottom:2px">${f.name}</div><div style="font-size:0.8rem;color:var(--text2)">${f.description}</div></div>`).join('')}
  </div>
  <div class="bd-section"><div class="bd-section-title">Argument Strength by Dimension</div>
    <div class="strength-bar-wrap">
      ${Object.entries(str).map(([k,v])=>`<div class="strength-row"><div class="strength-label-row"><span>${k.charAt(0).toUpperCase()+k.slice(1)}</span><span>${v}/10</span></div><div class="strength-bar"><div class="strength-fill" style="width:${v*10}%"></div></div></div>`).join('')}
    </div>
  </div>`;
}
 
