function renderQuiz(lesson) {
  const qs = lesson.quiz || [];
  let html = `<div class="lesson-body">`;
  qs.forEach((q, qi) => {
    html += `
    <div class="quiz-section" id="quiz-${lesson.id}-${qi}">
      <div class="quiz-header">
        <span class="quiz-badge">Question ${qi + 1} of ${qs.length}</span>
      </div>
      <div class="quiz-q">${q.q}</div>
      <div class="quiz-opts" id="opts-${lesson.id}-${qi}">
        ${q.opts.map((opt, oi) => `<button class="quiz-opt" data-qi="${qi}" data-oi="${oi}" data-ans="${q.ans}" data-lid="${lesson.id}" data-exp="${encodeURIComponent(q.exp || '')}" onclick="answerQuiz(this)">${opt}</button>`).join('')}
      </div>
      <div id="qfb-${lesson.id}-${qi}"></div>
    </div>`;
  });
  html += `</div>`;
  return html;
}
 
function initQuiz(lesson) {}
 
function answerQuiz(btn) {
  const qi = +btn.dataset.qi;
  const oi = +btn.dataset.oi;
  const ans = +btn.dataset.ans;
  const lid = btn.dataset.lid;
  const exp = decodeURIComponent(btn.dataset.exp || '');
  const optsContainer = document.getElementById(`opts-${lid}-${qi}`);
  if (!optsContainer) return;
  const opts = optsContainer.querySelectorAll('.quiz-opt');
  opts.forEach(o => o.disabled = true);
  opts[ans].classList.add('correct');
  if (oi !== ans) opts[oi].classList.add('wrong');
  const fb = document.getElementById(`qfb-${lid}-${qi}`);
  const correct = oi === ans;
  fb.innerHTML = `<div class="quiz-feedback ${correct ? 'success' : 'fail'}">${correct ? '✓ Correct! ' : '✗ Not quite. '}${exp}</div>`;
  if (correct) {
    completedLessons.add(lid + '-q' + qi);
    // Mark quiz lesson as done when all questions answered
    const lesson = ALL_LESSONS.find(l => l.id === lid);
    if (lesson) {
      const allAnswered = lesson.quiz.every((_, i) => document.getElementById(`qfb-${lid}-${i}`)?.innerHTML);
      if (allAnswered) { completedLessons.add(lid); updateProgress(); buildSidebar(); }
    }
  }
}
 
