function buildSidebar(filter) {
  const container = document.getElementById('sidebar-units');
  container.innerHTML = '';
  CURRICULUM.forEach((unit, ui) => {
    const isOpen = unitOpen[ui] !== false;
    const matchingLessons = filter
      ? unit.lessons.filter(l => l.title.toLowerCase().includes(filter.toLowerCase()))
      : unit.lessons;
    if (filter && matchingLessons.length === 0) return;
    const unitDiv = document.createElement('div');
    unitDiv.className = 'sidebar-unit';
    const header = document.createElement('div');
    header.className = 'unit-header';
    header.innerHTML = `
      <span class="unit-number">${unit.unit}</span>
      <span class="unit-name">${unit.name}</span>
      <span class="unit-chevron ${isOpen ? 'open' : ''}" id="chevron-${ui}">▶</span>`;
    header.onclick = () => { unitOpen[ui] = !isOpen; buildSidebar(filter); };
    unitDiv.appendChild(header);
    if (isOpen || filter) {
      const lessonsDiv = document.createElement('div');
      lessonsDiv.className = 'unit-lessons';
      matchingLessons.forEach(lesson => {
        const g = ALL_LESSONS.find(l => l.id === lesson.id)?.globalIndex ?? 0;
        const isDone = completedLessons.has(lesson.id);
        const isActive = g === currentGlobal;
        const typeMap = { lesson: 'tag-lesson', quiz: 'tag-quiz', exercise: 'tag-exercise', practice: 'tag-practice' };
        const li = document.createElement('div');
        li.className = `lesson-item${isDone ? ' done' : ''}${isActive ? ' active' : ''}`;
        li.id = `sidebar-${lesson.id}`;
        li.innerHTML = `
          <div class="lesson-status${isDone ? ' done' : isActive ? ' active' : ''}">${isDone ? '✓' : isActive ? '►' : ''}</div>
          <span style="flex:1">${lesson.title}</span>
          <span class="lesson-type-tag ${typeMap[lesson.type] || 'tag-lesson'}">${lesson.type}</span>`;
        li.onclick = () => loadLesson(g);
        lessonsDiv.appendChild(li);
      });
      unitDiv.appendChild(lessonsDiv);
    }
    container.appendChild(unitDiv);
  });
  updateProgress();
}
 
